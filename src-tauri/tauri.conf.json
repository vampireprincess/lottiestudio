{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Lottie Studio",
  "version": "1.0.0",
  "identifier": "com.lottie-studio.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Lottie Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "Graphics",
    "shortDescription": "Professional SVG and Lottie animation editor",
    "longDescription": "Lottie Studio is a professional local animation editor for SVG and Lottie files. Works completely offline — no cloud, no account required.",
    "windows": {
      "wix": {},
      "nsis": {
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "fs": {
      "all": true,
      "readFile": true,
      "writeFile": true,
      "readDir": true,
      "copyFile": true,
      "createDir": true,
      "removeDir": true,
      "removeFile": true,
      "renameFile": true,
      "exists": true
    },
    "dialog": {
      "all": true
    },
    "shell": {
      "all": false,
      "open": true
    },
    "path": {
      "all": true
    }
  }
}
